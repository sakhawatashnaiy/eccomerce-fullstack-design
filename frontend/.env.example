# Backend API base URL
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Firebase client (Vite)
# Create a Firebase Web App in Firebase Console, then paste the config values here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Optional admin allow-list for the frontend protected admin route.
# Comma-separated emails, e.g. "admin@example.com, other@domain.com"
VITE_ADMIN_EMAILS=
