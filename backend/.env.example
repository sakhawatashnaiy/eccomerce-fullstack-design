# Server
PORT=5000
NODE_ENV=development

# Admin allowlist (optional)
# Comma-separated Firebase user UIDs and/or emails allowed to access admin APIs.
# You can use either (or both). If left empty, only Firebase custom claim `admin: true`
# or a Firestore user profile with role `admin` will grant access.
# NOTE: The backend also accepts `VITE_ADMIN_UIDS` / `VITE_ADMIN_EMAILS` as fallbacks
# so you can reuse the same env naming as the frontend if you want.
ADMIN_UIDS=
ADMIN_EMAILS=

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Firebase Admin SDK
# Option A: keep this as raw JSON text (single line), not a file path.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/..."}

# Option B: split credentials (recommended when pasting private key manually)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
FIREBASE_PRIVATE_KEY_ID=optional-private-key-id
